<UserControl
    x:Class="Admin.Views.StaffManagement"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:Admin.ViewModels"
    x:DataType="vm:StaffManagementViewModel">
    <TabControl Margin="5" SelectedIndex="{Binding SelectedTabIndex}">
        <TabItem Header="Staff">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <!--  Search bar  -->
                    <RowDefinition Height="*" />
                    <!--  DataGrid  -->
                    <RowDefinition Height="Auto" />
                    <!--  Pagination buttons  -->
                </Grid.RowDefinitions>
                <DataGrid
                    Grid.Row="1"
                    MinHeight="200"
                    MaxHeight="500"
                    Margin="10"
                    AutoGenerateColumns="False"
                    IsReadOnly="True"
                    ItemsSource="{Binding Staff}">

                    <DataGrid.Columns>
                        <DataGridTextColumn Binding="{Binding FirstName}" Header="First Name" />
                        <DataGridTextColumn Binding="{Binding LastName}" Header="Last Name" />
                        <DataGridTextColumn Binding="{Binding UserName}" Header="Username" />


                        <!--  ✅ Button Group Column  -->
                        <DataGridTemplateColumn Width="Auto" Header="Actions">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="5">
                                        <!--  Edit Staff  -->
                                        <Button
                                            Command="{Binding $parent[UserControl].((vm:StaffManagementViewModel)DataContext).EditStaffCommand}"
                                            CommandParameter="{Binding}"
                                            ToolTip.Tip="Edit Scanner">
                                            <Image
                                                Width="16"
                                                Height="16"
                                                Source="{SvgImage avares://Admin/Assets/pencil.svg}" />
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <StackPanel
                    Grid.Row="2"
                    Margin="10"
                    HorizontalAlignment="Center"
                    IsVisible="{Binding !IsLoading}"
                    Orientation="Horizontal"
                    Spacing="8">
                    <Button Command="{Binding FirstPageCommand}" Content="First" />
                    <Button Command="{Binding PrevPageCommand}" Content="Previous" />

                    <TextBlock VerticalAlignment="Center" Text="{Binding PageInfo}" />

                    <Button Command="{Binding NextPageCommand}" Content="Next" />
                    <Button Command="{Binding LastPageCommand}" Content="Last" />
                </StackPanel>

                <!--  Loading Layer covering entire content  -->
                <Border
                    Grid.Row="0"
                    Grid.RowSpan="3"
                    Background="White"
                    IsVisible="{Binding IsLoading}"
                    Opacity="0.8">
                    <Grid>
                        <ProgressBar
                            Width="150"
                            Height="10"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            IsIndeterminate="True" />
                    </Grid>
                </Border>
            </Grid>
        </TabItem>
        <TabItem Header="{Binding FormTabText}">
            <Border
                Padding="10"
                HorizontalAlignment="Stretch"
                BorderBrush="Gray"
                BorderThickness="1"
                CornerRadius="5">
                <StackPanel Spacing="5">
                    <TextBlock FontWeight="Bold" Text="First Name:" />
                    <TextBox HorizontalAlignment="Stretch" Text="{Binding StaffFirstName}" />

                    <TextBlock FontWeight="Bold" Text="Last Name:" />
                    <TextBox HorizontalAlignment="Stretch" Text="{Binding StaffLastName}" />

                    <TextBlock FontWeight="Bold" Text="Email:" />
                    <TextBox HorizontalAlignment="Stretch" Text="{Binding StaffEmail}" />

                    <TextBlock FontWeight="Bold" Text="Username:" />
                    <TextBox HorizontalAlignment="Stretch" Text="{Binding StaffUsername}" />
                    <TextBlock FontWeight="Bold" Text="Password:" />
                    <TextBox HorizontalAlignment="Stretch" Text="{Binding StaffPassword}" />


                    <StackPanel Orientation="Horizontal">
                        <Button Command="{Binding SubmitStaffCommand}" Content="Save" />
                        <Button
                            Margin="8,0,0,0"
                            Command="{Binding ClearStaffFormCommand}"
                            Content="Cancel" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </TabItem>
    </TabControl>
</UserControl>
