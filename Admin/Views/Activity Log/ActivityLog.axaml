<UserControl
    x:Class="Admin.Views.ActivityLog"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ae="clr-namespace:Avalonia.Extensions.Controls"
    xmlns:libs-models="using:Libs.Data.Models"
    xmlns:local="clr-namespace:Admin"
    xmlns:vm="clr-namespace:Admin.ViewModels"
    x:Name="ActivityLogView"
    x:DataType="vm:ActivityLogViewModel">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <!--  Search bar  -->
            <RowDefinition Height="*" />
            <!--  DataGrid  -->
            <RowDefinition Height="Auto" />
            <!--  Pagination buttons  -->
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="LightGray">
            <StackPanel
                Margin="5"
                Orientation="Horizontal"
                Spacing="10">
                <ComboBox
                    Width="150"
                    DockPanel.Dock="Right"
                    ItemsSource="{Binding AreaOptions}"
                    SelectedItem="{Binding SelectedArea, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Key}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <ComboBox
                    Width="150"
                    DockPanel.Dock="Left"
                    ItemsSource="{Binding LogLevelOptions}"
                    SelectedItem="{Binding SelectedLogLevel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Key}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>
        </Border>

        <!--  Logs table  -->
        <DataGrid
            Grid.Row="1"
            Margin="10"
            AutoGenerateColumns="False"
            CanUserResizeColumns="True"
            HorizontalScrollBarVisibility="Auto"
            IsReadOnly="True"
            IsVisible="{Binding !IsLoading}"
            ItemsSource="{Binding Logs}"
            VerticalScrollBarVisibility="Auto">

            <DataGrid.Columns>
                <DataGridTextColumn Binding="{Binding Id}" Header="ID" />
                <DataGridTextColumn Binding="{Binding Level}" Header="Log Level" />
                <DataGridTextColumn Binding="{Binding Area}" Header="Area" />
                <DataGridTextColumn Binding="{Binding Message}" Header="Message" />
            </DataGrid.Columns>

        </DataGrid>

        <StackPanel
            Grid.Row="2"
            Margin="10"
            HorizontalAlignment="Center"
            IsVisible="{Binding !IsLoading}"
            Orientation="Horizontal"
            Spacing="8">
            <Button Command="{Binding FirstPageCommand}" Content="First" />
            <Button Command="{Binding PrevPageCommand}" Content="Previous" />
            
            <TextBlock VerticalAlignment="Center" Text="{Binding PageInfo}" />
            
            <Button Command="{Binding NextPageCommand}" Content="Next" />
            <Button Command="{Binding LastPageCommand}" Content="Last" />
        </StackPanel>

        <!--  Loading Layer covering entire content  -->
        <Border
            Grid.Row="0"
            Grid.RowSpan="3"
            Background="White"
            IsVisible="{Binding IsLoading}"
            Opacity="0.8">
            <Grid>
                <ProgressBar
                    Width="150"
                    Height="10"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    IsIndeterminate="True" />
            </Grid>
        </Border>
    </Grid>

</UserControl>
