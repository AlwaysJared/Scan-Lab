<UserControl
    x:Class="Admin.Views.Dashboard"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Admin.ViewModels"
    x:DataType="vm:DashboardViewModel">

    <ScrollViewer>
        <Grid Margin="24">
            <!--  Card that responsively fills half the window width  -->
            <!--  MaxWidth="{Binding $parent[Window].Bounds.Width, Converter={StaticResource HalfWidthConverter}}"  -->
            <Border
                Padding="24"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                CornerRadius="16">

                <Grid RowDefinitions="Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto">


                    <!--  Title Header  -->
                    <TextBlock
                        Grid.Row="0"
                        Margin="0,0,0,8"
                        FontSize="24"
                        FontWeight="SemiBold"
                        Text="Orders by Staff" />

                    <!--  Content Area  -->
                    <StackPanel Grid.Row="1" Spacing="16">

                        <!--  FILTER BAR  -->
                        <!--  Background="{DynamicResource ThemeControlLowBrush}"  -->
                        <Border
                            Margin="0,0,0,8"
                            Padding="12"
                            CornerRadius="8">
                            <StackPanel
                                VerticalAlignment="Center"
                                Orientation="Horizontal"
                                Spacing="20">

                                <StackPanel>
                                    <TextBlock
                                        Margin="0,0,0,4"
                                        FontWeight="SemiBold"
                                        Text="Select Items" />

                                    <ToggleButton
                                        x:Name="DropdownButton"
                                        Width="180"
                                        Content="Select Items"
                                        IsChecked="{Binding IsDropdownOpen, Mode=TwoWay}" />

                                    <Popup IsOpen="{Binding IsDropdownOpen, Mode=TwoWay}" PlacementTarget="{Binding ElementName=DropdownButton}">
                                        <Border
                                            Padding="4"
                                            Background="White"
                                            BorderBrush="Gray"
                                            BorderThickness="1"
                                            CornerRadius="4">
                                            <ScrollViewer MaxHeight="120">
                                                <ItemsControl ItemsSource="{Binding AvailableOptions}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <CheckBox Content="{Binding Label}" IsChecked="{Binding IsSelected, Mode=TwoWay}" />
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </ScrollViewer>
                                        </Border>
                                    </Popup>
                                </StackPanel>


                                <!--  Date range  -->
                                <StackPanel>
                                    <TextBlock
                                        Margin="0,0,0,4"
                                        FontWeight="SemiBold"
                                        Text="Date Range" />
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <CalendarDatePicker Width="130" SelectedDate="{Binding StartDate}" />
                                        <TextBlock VerticalAlignment="Center" Text="to" />
                                        <CalendarDatePicker Width="130" SelectedDate="{Binding EndDate}" />
                                    </StackPanel>
                                </StackPanel>

                                <!--  Toggle  -->
                                <StackPanel>
                                    <TextBlock
                                        Margin="0,0,0,4"
                                        FontWeight="SemiBold"
                                        Text="Average?" />
                                    <ToggleSwitch IsChecked="{Binding IncludeArchived}" />
                                </StackPanel>

                                <!--  Apply Filter Button  -->
                                <Button
                                    Height="32"
                                    VerticalAlignment="Bottom"
                                    Command="{Binding OrdersPerStaffCommand}"
                                    Content="Apply Filters" />
                            </StackPanel>
                        </Border>
                        <!--  TABLE  -->
                        <DataGrid
                            AutoGenerateColumns="False"
                            CornerRadius="8"
                            GridLinesVisibility="All"
                            HeadersVisibility="Column"
                            IsReadOnly="True"
                            ItemsSource="{Binding TableItems}"
                            RowHeight="32">

                            <DataGrid.Columns>
                                <DataGridTextColumn
                                    Width="*"
                                    Binding="{Binding Id}"
                                    Header="ID" />
                                <DataGridTextColumn
                                    Width="*"
                                    Binding="{Binding Name}"
                                    Header="Name" />
                                <DataGridTextColumn
                                    Width="*"
                                    Binding="{Binding Value}"
                                    Header="" />
                            </DataGrid.Columns>
                        </DataGrid>

                    </StackPanel>

                    <!--  Title Header  -->
                    <TextBlock
                        Grid.Row="2"
                        Margin="0,30,0,8"
                        FontSize="24"
                        FontWeight="SemiBold"
                        Text="Rolls by Staff" />

                    <!--  Content Area  -->
                    <StackPanel Grid.Row="3" Spacing="16">

                        <!--  FILTER BAR  -->
                        <Border
                            Margin="0,0,0,8"
                            Padding="12"
                            CornerRadius="8">
                            <StackPanel
                                VerticalAlignment="Center"
                                Orientation="Horizontal"
                                Spacing="20">

                                <StackPanel>
                                    <TextBlock
                                        Margin="0,0,0,4"
                                        FontWeight="SemiBold"
                                        Text="Select Items" />

                                    <ToggleButton
                                        x:Name="RollsPerStaffDropdownButton"
                                        Width="180"
                                        Content="Select Items"
                                        IsChecked="{Binding IsRollsPerStaffDropdownOpen, Mode=TwoWay}" />

                                    <Popup IsOpen="{Binding IsRollsPerStaffDropdownOpen, Mode=TwoWay}" PlacementTarget="{Binding ElementName=RollsPerStaffDropdownButton}">
                                        <Border
                                            Padding="4"
                                            Background="White"
                                            BorderBrush="Gray"
                                            BorderThickness="1"
                                            CornerRadius="4">
                                            <ScrollViewer MaxHeight="120">
                                                <ItemsControl ItemsSource="{Binding RollsPerStaffAvailableOptions}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <CheckBox Content="{Binding Label}" IsChecked="{Binding IsSelected, Mode=TwoWay}" />
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </ScrollViewer>
                                        </Border>
                                    </Popup>
                                </StackPanel>


                                <!--  Date range  -->
                                <StackPanel>
                                    <TextBlock
                                        Margin="0,0,0,4"
                                        FontWeight="SemiBold"
                                        Text="Date Range" />
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <CalendarDatePicker Width="130" SelectedDate="{Binding RollsPerStaffStartDate}" />
                                        <TextBlock VerticalAlignment="Center" Text="to" />
                                        <CalendarDatePicker Width="130" SelectedDate="{Binding RollsPerStaffEndDate}" />
                                    </StackPanel>
                                </StackPanel>

                                <!--  Toggle  -->
                                <StackPanel>
                                    <TextBlock
                                        Margin="0,0,0,4"
                                        FontWeight="SemiBold"
                                        Text="Average?" />
                                    <ToggleSwitch IsChecked="{Binding RollsPerStaffIncludeArchived}" />
                                </StackPanel>

                                <!--  Apply Filter Button  -->
                                <Button
                                    Height="32"
                                    VerticalAlignment="Bottom"
                                    Command="{Binding RollsPerStaffCommand}"
                                    Content="Apply" />
                            </StackPanel>
                        </Border>
                        <!--  TABLE  -->
                        <DataGrid
                            AutoGenerateColumns="False"
                            CornerRadius="8"
                            GridLinesVisibility="All"
                            HeadersVisibility="Column"
                            IsReadOnly="True"
                            ItemsSource="{Binding RollsPerStaffTableItems}"
                            RowHeight="32">

                            <DataGrid.Columns>
                                <DataGridTextColumn
                                    Width="*"
                                    Binding="{Binding Id}"
                                    Header="ID" />
                                <DataGridTextColumn
                                    Width="*"
                                    Binding="{Binding Name}"
                                    Header="Name" />
                                <DataGridTextColumn
                                    Width="*"
                                    Binding="{Binding Value}"
                                    Header="" />
                            </DataGrid.Columns>
                        </DataGrid>

                    </StackPanel>

                    <!--  Title Header  -->
                    <TextBlock
                        Grid.Row="4"
                        Margin="0,30,0,8"
                        FontSize="24"
                        FontWeight="SemiBold"
                        Text="Orders by Scanner" />

                    <!--  Content Area  -->
                    <StackPanel Grid.Row="5" Spacing="16">

                        <!--  FILTER BAR  -->
                        <Border
                            Margin="0,0,0,8"
                            Padding="12"
                            CornerRadius="8">
                            <StackPanel
                                VerticalAlignment="Center"
                                Orientation="Horizontal"
                                Spacing="20">

                                <StackPanel>
                                    <TextBlock
                                        Margin="0,0,0,4"
                                        FontWeight="SemiBold"
                                        Text="Select Scanner(s)" />

                                    <ToggleButton
                                        x:Name="OrdersPerScannerDropdownButton"
                                        Width="180"
                                        Content="Select Scanner(s)"
                                        IsChecked="{Binding IsOrdersPerScannerDropdownOpen, Mode=TwoWay}" />

                                    <Popup IsOpen="{Binding IsOrdersPerScannerDropdownOpen, Mode=TwoWay}" PlacementTarget="{Binding ElementName=OrdersPerScannerDropdownButton}">
                                        <Border
                                            Padding="4"
                                            Background="White"
                                            BorderBrush="Gray"
                                            BorderThickness="1"
                                            CornerRadius="4">
                                            <ScrollViewer MaxHeight="120">
                                                <ItemsControl ItemsSource="{Binding OrdersPerScannerAvailableOptions}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <CheckBox Content="{Binding Label}" IsChecked="{Binding IsSelected, Mode=TwoWay}" />
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </ScrollViewer>
                                        </Border>
                                    </Popup>
                                </StackPanel>


                                <!--  Date range  -->
                                <StackPanel>
                                    <TextBlock
                                        Margin="0,0,0,4"
                                        FontWeight="SemiBold"
                                        Text="Date Range" />
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <CalendarDatePicker Width="130" SelectedDate="{Binding OrdersPerScannerStartDate}" />
                                        <TextBlock VerticalAlignment="Center" Text="to" />
                                        <CalendarDatePicker Width="130" SelectedDate="{Binding OrdersPerScannerEndDate}" />
                                    </StackPanel>
                                </StackPanel>

                                <!--  Toggle  -->
                                <StackPanel>
                                    <TextBlock
                                        Margin="0,0,0,4"
                                        FontWeight="SemiBold"
                                        Text="Average?" />
                                    <ToggleSwitch IsChecked="{Binding OrdersPerScannerIncludeArchived}" />
                                </StackPanel>

                                <!--  Apply Filter Button  -->
                                <Button
                                    Height="32"
                                    VerticalAlignment="Bottom"
                                    Command="{Binding OrdersPerScannerCommand}"
                                    Content="Apply" />
                            </StackPanel>
                        </Border>
                        <!--  TABLE  -->
                        <DataGrid
                            AutoGenerateColumns="False"
                            CornerRadius="8"
                            GridLinesVisibility="All"
                            HeadersVisibility="Column"
                            IsReadOnly="True"
                            ItemsSource="{Binding OrdersPerScannerTableItems}"
                            RowHeight="32">

                            <DataGrid.Columns>
                                <DataGridTextColumn
                                    Width="*"
                                    Binding="{Binding Id}"
                                    Header="ID" />
                                <DataGridTextColumn
                                    Width="*"
                                    Binding="{Binding Name}"
                                    Header="Name" />
                                <DataGridTextColumn
                                    Width="*"
                                    Binding="{Binding Value}"
                                    Header="" />
                            </DataGrid.Columns>
                        </DataGrid>

                    </StackPanel>

                    <!--  Title Header  -->
                    <TextBlock
                        Grid.Row="6"
                        Margin="0,30,0,8"
                        FontSize="24"
                        FontWeight="SemiBold"
                        Text="Rolls by Scanner" />

                    <!--  Content Area  -->
                    <StackPanel Grid.Row="7" Spacing="16">

                        <!--  FILTER BAR  -->
                        <Border
                            Margin="0,0,0,8"
                            Padding="12"
                            CornerRadius="8">
                            <StackPanel
                                VerticalAlignment="Center"
                                Orientation="Horizontal"
                                Spacing="20">

                                <StackPanel>
                                    <TextBlock
                                        Margin="0,0,0,4"
                                        FontWeight="SemiBold"
                                        Text="Select Scanner(s)" />

                                    <ToggleButton
                                        x:Name="RollsPerScannerDropdownButton"
                                        Width="180"
                                        Content="Select Scanner(s)"
                                        IsChecked="{Binding IsRollsPerScannerDropdownOpen, Mode=TwoWay}" />

                                    <Popup IsOpen="{Binding IsRollsPerScannerDropdownOpen, Mode=TwoWay}" PlacementTarget="{Binding ElementName=RollsPerScannerDropdownButton}">
                                        <Border
                                            Padding="4"
                                            Background="White"
                                            BorderBrush="Gray"
                                            BorderThickness="1"
                                            CornerRadius="4">
                                            <ScrollViewer MaxHeight="120">
                                                <ItemsControl ItemsSource="{Binding RollsPerScannerAvailableOptions}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <CheckBox Content="{Binding Label}" IsChecked="{Binding IsSelected, Mode=TwoWay}" />
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </ScrollViewer>
                                        </Border>
                                    </Popup>
                                </StackPanel>


                                <!--  Date range  -->
                                <StackPanel>
                                    <TextBlock
                                        Margin="0,0,0,4"
                                        FontWeight="SemiBold"
                                        Text="Date Range" />
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <CalendarDatePicker Width="130" SelectedDate="{Binding RollsPerScannerStartDate}" />
                                        <TextBlock VerticalAlignment="Center" Text="to" />
                                        <CalendarDatePicker Width="130" SelectedDate="{Binding RollsPerScannerEndDate}" />
                                    </StackPanel>
                                </StackPanel>

                                <!--  Toggle  -->
                                <StackPanel>
                                    <TextBlock
                                        Margin="0,0,0,4"
                                        FontWeight="SemiBold"
                                        Text="Average?" />
                                    <ToggleSwitch IsChecked="{Binding RollsPerScannerIncludeArchived}" />
                                </StackPanel>

                                <!--  Apply Filter Button  -->
                                <Button
                                    Height="32"
                                    VerticalAlignment="Bottom"
                                    Command="{Binding RollsPerScannerCommand}"
                                    Content="Apply" />
                            </StackPanel>
                        </Border>
                        <!--  TABLE  -->
                        <DataGrid
                            AutoGenerateColumns="False"
                            CornerRadius="8"
                            GridLinesVisibility="All"
                            HeadersVisibility="Column"
                            IsReadOnly="True"
                            ItemsSource="{Binding RollsPerScannerTableItems}"
                            RowHeight="32">

                            <DataGrid.Columns>
                                <DataGridTextColumn
                                    Width="*"
                                    Binding="{Binding Id}"
                                    Header="ID" />
                                <DataGridTextColumn
                                    Width="*"
                                    Binding="{Binding Name}"
                                    Header="Name" />
                                <DataGridTextColumn
                                    Width="*"
                                    Binding="{Binding Value}"
                                    Header="" />
                            </DataGrid.Columns>
                        </DataGrid>

                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
