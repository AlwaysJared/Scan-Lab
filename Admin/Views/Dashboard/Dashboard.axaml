<UserControl
    x:Class="Admin.Views.Dashboard"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Admin.ViewModels"
    x:DataType="vm:DashboardViewModel">

    <Grid Margin="24">
        <!--  Card that responsively fills half the window width  -->
        <Border
            MaxWidth="{Binding $parent[Window].Bounds.Width, Converter={StaticResource HalfWidthConverter}}"
            Padding="24"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Background="{DynamicResource CardBackgroundBrush}"
            BoxShadow="0 2 8 #00000020"
            CornerRadius="16">

            <Grid RowDefinitions="Auto, *">
                <!--  Title Header  -->
                <TextBlock
                    Grid.Row="0"
                    Margin="0,0,0,8"
                    FontSize="24"
                    FontWeight="SemiBold"
                    Text="Dashboard" />

                <!--  Content Area  -->
                <StackPanel Grid.Row="1" Spacing="16">

                    <!--  FILTER BAR  -->

                    <!--  Background="{DynamicResource ThemeControlLowBrush}"  -->
                    <Border
                        Margin="0,0,0,8"
                        Padding="12"
                        Background="#FFF000"
                        CornerRadius="8">
                        <StackPanel
                            VerticalAlignment="Center"
                            Orientation="Horizontal"
                            Spacing="20">

                            <StackPanel>
                                <TextBlock
                                    Margin="0,0,0,4"
                                    FontWeight="SemiBold"
                                    Text="Select Items" />

                                <ToggleButton
                                    x:Name="DropdownButton"
                                    Width="180"
                                    Content="Select Items"
                                    IsChecked="{Binding IsDropdownOpen, Mode=TwoWay}" />

                                <Popup IsOpen="{Binding IsDropdownOpen, Mode=TwoWay}" PlacementTarget="{Binding ElementName=DropdownButton}">
                                    <Border
                                        Padding="4"
                                        Background="White"
                                        BorderBrush="Gray"
                                        BorderThickness="1"
                                        CornerRadius="4">
                                        <ScrollViewer MaxHeight="120">
                                            <ItemsControl ItemsSource="{Binding AvailableOptions}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <CheckBox Content="{Binding Label}" IsChecked="{Binding IsSelected, Mode=TwoWay}" />
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </Border>
                                </Popup>
                            </StackPanel>


                            <!--  Date range  -->
                            <StackPanel>
                                <TextBlock
                                    Margin="0,0,0,4"
                                    FontWeight="SemiBold"
                                    Text="Date Range" />
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <CalendarDatePicker  Width="130" SelectedDate="{Binding StartDate}" />
                                    <TextBlock VerticalAlignment="Center" Text="to" />
                                    <CalendarDatePicker  Width="130" SelectedDate="{Binding EndDate}" />
                                </StackPanel>
                            </StackPanel>

                            <!--  Toggle  -->
                            <StackPanel>
                                <TextBlock
                                    Margin="0,0,0,4"
                                    FontWeight="SemiBold"
                                    Text="Include Archived" />
                                <ToggleSwitch IsChecked="{Binding IncludeArchived}" />
                            </StackPanel>

                            <!--  Apply Filter Button  -->
                            <Button
                                Height="32"
                                VerticalAlignment="Bottom"
                                Command="{Binding OrdersPerStaffCommand}"
                                Content="Apply Filters" />
                        </StackPanel>
                    </Border>

                    <!--  TABLE  -->
                    <DataGrid
                        AutoGenerateColumns="False"
                        CornerRadius="8"
                        GridLinesVisibility="All"
                        HeadersVisibility="Column"
                        IsReadOnly="True"
                        ItemsSource="{Binding TableItems}"
                        RowHeight="32">

                        <DataGrid.Columns>
                            <DataGridTextColumn
                                Width="Auto"
                                Binding="{Binding Id}"
                                Header="ID" />
                            <DataGridTextColumn
                                Width="*"
                                Binding="{Binding Name}"
                                Header="Name" />
                            <DataGridTextColumn
                                Width="*"
                                Binding="{Binding Value}"
                                Header="" />
                        </DataGrid.Columns>
                    </DataGrid>

                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
