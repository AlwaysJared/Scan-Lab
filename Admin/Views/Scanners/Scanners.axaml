<UserControl
    x:Class="Admin.Views.Scanners"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:Admin.ViewModels"
    x:DataType="vm:ScannersViewModel">
    <TabControl Margin="5" SelectedIndex="{Binding SelectedTabIndex}">
        <TabItem Header="Scanner List">
            <DataGrid
                Grid.Row="1"
                MinHeight="200"
                MaxHeight="500"
                Margin="10"
                AutoGenerateColumns="False"
                IsReadOnly="True"
                ItemsSource="{Binding Scanners}">

                <DataGrid.Columns>
                    <DataGridTextColumn Binding="{Binding ScannerName}" Header="Name" />
                    <DataGridTextColumn Binding="{Binding Make}" Header="Make" />
                    <DataGridTextColumn Binding="{Binding Model}" Header="Model" />
                    <DataGridTextColumn Binding="{Binding ArtistName}" Header="Artist Name" />
                    <DataGridTextColumn Binding="{Binding Profile.ProfileName}" Header="Profile" />


                    <!--  ✅ Button Group Column  -->
                    <DataGridTemplateColumn Width="Auto" Header="Actions">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="5">
                                    <!--  Edit Scanner  -->
                                    <Button
                                        Command="{Binding $parent[UserControl].((vm:ScannersViewModel)DataContext).EditScannerCommand}"
                                        CommandParameter="{Binding}"
                                        ToolTip.Tip="Edit Scanner">
                                        <Image
                                            Width="16"
                                            Height="16"
                                            Source="{SvgImage avares://Admin/Assets/pencil.svg}" />
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </TabItem>
        <TabItem Header="{Binding FormTabText}">
            <Border
                Padding="10"
                HorizontalAlignment="Stretch"
                BorderBrush="Gray"
                BorderThickness="1"
                CornerRadius="5">
                <StackPanel Spacing="5">
                    <TextBlock FontWeight="Bold" Text="Scanner Name:" />
                    <TextBox HorizontalAlignment="Stretch" Text="{Binding ScannerName}" />

                    <TextBlock FontWeight="Bold" Text="Make:" />
                    <TextBox HorizontalAlignment="Stretch" Text="{Binding ScannerMake}" />

                    <TextBlock FontWeight="Bold" Text="Model:" />
                    <TextBox HorizontalAlignment="Stretch" Text="{Binding ScannerModel}" />

                    <TextBlock FontWeight="Bold" Text="Artist Name:" />
                    <TextBox HorizontalAlignment="Stretch" Text="{Binding ArtistName}" />

                    <!--  Scanner Profile  -->
                    <TextBlock FontWeight="Bold" Text="Scanner Profile:" />
                    <ComboBox
                        HorizontalAlignment="Stretch"
                        DisplayMemberBinding="{Binding ProfileName}"
                        ItemsSource="{Binding Profiles}"
                        SelectedItem="{Binding SelectedProfile}" />

                    <!--  Auto-Process Delay (only for Noritsu)  -->
                    <StackPanel IsVisible="{Binding ShowAutoProcessDelay}" Spacing="5">
                        <TextBlock FontWeight="Bold" Text="Auto-Process Delay (seconds):" />
                        <TextBox HorizontalAlignment="Stretch" Text="{Binding AutoProcessDelaySeconds}" />
                    </StackPanel>

                    <!--  Profile Configurations (when profile selected)  -->
                    <StackPanel IsVisible="{Binding HasProfileSelected}" Spacing="5">
                        <TextBlock
                            Margin="0,10,0,0"
                            FontWeight="Bold"
                            Text="Profile Configuration:" />
                        <ItemsControl ItemsSource="{Binding ProfileConfigurations}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,3" Spacing="2">
                                        <TextBlock
                                            FontStyle="Italic"
                                            Foreground="Gray"
                                            Text="{Binding Description}" />
                                        <TextBox HorizontalAlignment="Stretch" Text="{Binding ConfigValue, Mode=TwoWay}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <TextBlock FontWeight="Bold" Text="Watched Directory:" />
                    <Grid HorizontalAlignment="Stretch" ColumnDefinitions="*,Auto">
                        <TextBox
                            Name="WatchedDirPathTextBox"
                            Grid.Column="0"
                            IsReadOnly="True"
                            Text="{Binding WatchedFolderPath}" />
                        <Button
                            Grid.Column="1"
                            Margin="8,0,0,0"
                            Command="{Binding SelectFolderCommand}"
                            CommandParameter="WatchedDir"
                            Content="Browse" />
                    </Grid>

                    <TextBlock FontWeight="Bold" Text="Destination Directory:" />
                    <Grid HorizontalAlignment="Stretch" ColumnDefinitions="*,Auto">
                        <TextBox
                            Grid.Column="0"
                            IsReadOnly="True"
                            Text="{Binding DestFolderPath}" />
                        <Button
                            Grid.Column="1"
                            Margin="8,0,0,0"
                            Command="{Binding SelectFolderCommand}"
                            CommandParameter="DestinationDir"
                            Content="Browse" />
                    </Grid>

                    <TextBlock FontWeight="Bold" Text="Archive Directory:" />
                    <Grid HorizontalAlignment="Stretch" ColumnDefinitions="*,Auto">
                        <TextBox
                            Grid.Column="0"
                            IsReadOnly="True"
                            Text="{Binding ArchiveFolderPath}" />
                        <Button
                            Grid.Column="1"
                            Margin="8,0,0,0"
                            Command="{Binding SelectFolderCommand}"
                            CommandParameter="ArchiveDir"
                            Content="Browse" />
                    </Grid>
                    <StackPanel Orientation="Horizontal">
                        <Button Command="{Binding SubmitScannerCommand}" Content="Save" />
                        <Button
                            Margin="8,0,0,0"
                            Command="{Binding ClearScannerFormCommand}"
                            Content="Cancel" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </TabItem>
    </TabControl>
</UserControl>
