<UserControl
    x:Class="Client.Views.Settings"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:viewModels="clr-namespace:Client.ViewModels"
    x:DataType="viewModels:SettingsViewModel">
    <ScrollViewer>
        <Grid
            Margin="20"
            ColumnDefinitions="*"
            RowDefinitions="Auto,Auto,*">

            <StackPanel
                Grid.Row="0"
                Grid.Column="0"
                HorizontalAlignment="Stretch"
                Spacing="10">

                <!--  Scanner Selection Dropdown with Loading Indicator  -->
                <TextBlock FontWeight="Bold" Text="Select Scanner:" />

                <!--  Show "Loading..." when fetching scanners  -->
                <TextBlock IsVisible="{Binding IsLoading}" Text="Loading scanners..." />

                <!--  Scanner Dropdown (Disabled when loading)  -->
                <ComboBox
                    x:Name="ScannerComboBox"
                    HorizontalAlignment="Stretch"
                    IsEnabled="{Binding IsNotLoading}"
                    ItemsSource="{Binding Scanners}"
                    SelectedItem="{Binding SelectedScanner}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding ScannerName}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>

                </ComboBox>
                <!--  Scanner Configuration Expander  -->
                <Expander
                    HorizontalAlignment="Stretch"
                    Header="Scanner Configuration"
                    IsExpanded="False">
                    <Border
                        Padding="10"
                        HorizontalAlignment="Stretch"
                        BorderBrush="Gray"
                        BorderThickness="1"
                        CornerRadius="5">
                        <StackPanel Spacing="5">
                            <TextBlock FontWeight="Bold" Text="Scanner Name:" />
                            <TextBox
                                HorizontalAlignment="Stretch"
                                Text="{Binding SelectedScanner.ScannerName}" />

                            <TextBlock FontWeight="Bold" Text="Make:" />
                            <TextBox
                                HorizontalAlignment="Stretch"
                                Text="{Binding SelectedScanner.Make}" />

                            <TextBlock FontWeight="Bold" Text="Model:" />
                            <TextBox
                                HorizontalAlignment="Stretch"
                                Text="{Binding SelectedScanner.Model}" />
                            
                            <TextBlock FontWeight="Bold" Text="Artist Name:" />
                            <TextBox
                                HorizontalAlignment="Stretch"
                                Text="{Binding SelectedScanner.ArtistName}" />

                            <TextBlock FontWeight="Bold" Text="Watched Directory:" />
                            <Grid HorizontalAlignment="Stretch" ColumnDefinitions="*,Auto">
                                <TextBox
                                    Grid.Column="0"
                                    IsReadOnly="True"
                                    Text="{Binding SelectedScanner.WatchedDir}" />
                                <Button
                                    Grid.Column="1"
                                    Command="{Binding SelectFolderCommand}"
                                    CommandParameter="WatchedDir"
                                    Content="Browse"
                                    Margin="8,0,0,0" />
                            </Grid>

                            <TextBlock FontWeight="Bold" Text="Destination Directory:" />
                            <Grid HorizontalAlignment="Stretch" ColumnDefinitions="*,Auto">
                                <TextBox
                                    Grid.Column="0"
                                    IsReadOnly="True"
                                    Text="{Binding SelectedScanner.DestinationDir}" />
                                <Button
                                    Grid.Column="1"
                                    Command="{Binding SelectFolderCommand}"
                                    CommandParameter="DestinationDir"
                                    Content="Browse"
                                    Margin="8,0,0,0" />
                            </Grid>

                            <TextBlock FontWeight="Bold" Text="Archive Directory:" />
                            <Grid HorizontalAlignment="Stretch" ColumnDefinitions="*,Auto">
                                <TextBox
                                    Grid.Column="0"
                                    IsReadOnly="True"
                                    Text="{Binding SelectedScanner.ArchiveDir}" />
                                <Button
                                    Grid.Column="1"
                                    Command="{Binding SelectFolderCommand}"
                                    CommandParameter="ArchiveDir"
                                    Content="Browse"
                                    Margin="8,0,0,0" />
                            </Grid>
                            <StackPanel Orientation="Horizontal">
                                <Button
                                    Command="{Binding UpdateScannerCommand}"
                                    Content="Save" />
                                    <Button
                                    Command="{Binding CancelUpdateScannerCommand}"
                                    Content="Cancel" 
                                    Margin="8,0,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Expander>
                <!--  API Configuration Expander  -->
                <Expander
                    HorizontalAlignment="Stretch"
                    Header="API Configuration"
                    IsExpanded="False">
                    <Border
                        Padding="10"
                        HorizontalAlignment="Stretch"
                        BorderBrush="Gray"
                        BorderThickness="1"
                        CornerRadius="5">
                        <StackPanel Orientation="Vertical" Spacing="10">

                            <!--  API Address Input  -->
                            <TextBlock FontWeight="Bold" Text="Address:" />
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <TextBox Width="300" Text="{Binding ApiAddress, Mode=TwoWay}" />
                                <Button
                                    Width="60"
                                    Command="{Binding TestApiCommand}"
                                    Content="Test" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Expander>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
