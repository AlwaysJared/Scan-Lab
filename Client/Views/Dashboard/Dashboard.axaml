<UserControl
    x:Class="Client.Views.Dashboard"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ae="clr-namespace:Avalonia.Extensions.Controls"
    xmlns:libs-models="using:Libs.Data.Models"
    xmlns:local="clr-namespace:Client"
    xmlns:vm="clr-namespace:Client.ViewModels"
    x:Name="DashboardView"
    x:DataType="vm:DashboardViewModel">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <!--  Search bar row  -->
            <RowDefinition Height="Auto" />
            <!--  Active Exports panel  -->
            <RowDefinition Height="Auto" />
            <!--  Orders table  -->
            <RowDefinition Height="*" />
            <!--  loading layer  -->
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="LightGray">
            <StackPanel
                Margin="5"
                Orientation="Horizontal"
                Spacing="10">
                <!--  Text search for orders  -->
                <TextBox
                    Width="200"
                    Text="{Binding SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    Watermark="Search orders..." />
                <!--  Status Filter  -->
                <ComboBox
                    Width="150"
                    DockPanel.Dock="Left"
                    ItemsSource="{Binding OrderStatusOptions}"
                    SelectedItem="{Binding SelectedOrderStatus, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Key}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <!--  Limit search to just the selected scanner profile (checked by default)  -->
                <CheckBox Content="Only orders for this scanner" IsChecked="{Binding ScannerSearchChecked}" />
                <!--  Show completed orders (unchecked by default)  -->
                <CheckBox Content="Show completed orders" IsChecked="{Binding CompletedOrdersChecked}" />
            </StackPanel>
        </Border>

        <!--  Active SP-500 Exports Panel  -->
        <Border
            Grid.Row="1"
            Margin="10,5"
            Padding="8"
            Background="#FFF3CD"
            BorderBrush="#FFD700"
            BorderThickness="1"
            CornerRadius="4"
            IsVisible="{Binding HasActiveExports}">
            <StackPanel>
                <TextBlock
                    Margin="0,0,0,5"
                    FontWeight="Bold"
                    Text="Active SP-500 Exports" />
                <ItemsControl ItemsSource="{Binding ActiveExports}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel
                                Margin="0,2"
                                Orientation="Horizontal"
                                Spacing="15">
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontWeight="SemiBold"
                                    Text="{Binding Status}" />
                                <TextBlock
                                    VerticalAlignment="Center"
                                    Text="{Binding DetectedRollNumber, StringFormat='Roll: {0}'}" />
                                <TextBlock
                                    VerticalAlignment="Center"
                                    Text="{Binding ImagesExported, StringFormat='{0} images'}" />
                                <Button
                                    Command="{Binding $parent[UserControl].((vm:DashboardViewModel)DataContext).StopExportByRollIdCommand}"
                                    CommandParameter="{Binding RollId}"
                                    Content="Stop"
                                    Padding="8,2" />
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <!--  Orders table  -->
        <DataGrid
            Grid.Row="2"
            Margin="10"
            AutoGenerateColumns="False"
            CanUserResizeColumns="True"
            IsReadOnly="True"
            IsVisible="{Binding !IsLoading}"
            ItemsSource="{Binding Orders}"
            RowDetailsVisibilityMode="VisibleWhenSelected">

            <DataGrid.Columns>
                <DataGridTextColumn Binding="{Binding OrderId}" Header="Order ID" />
                <DataGridTemplateColumn Header="Created" SortMemberPath="DateCreated">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock VerticalAlignment="Center">
                                <TextBlock.Text>
                                    <Binding Converter="{StaticResource NullableDateTimeConverter}" Path="DateCreated" />
                                </TextBlock.Text>
                            </TextBlock>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Updated" SortMemberPath="DateUpdated">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock VerticalAlignment="Center">
                                <TextBlock.Text>
                                    <Binding Converter="{StaticResource NullableDateTimeConverter}" Path="DateUpdated" />
                                </TextBlock.Text>
                            </TextBlock>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Binding="{Binding Customer.FirstName}" Header="Customer" />
                <DataGridTextColumn Binding="{Binding Scanner.ScannerName}" Header="Scanner" />
                <DataGridTextColumn Binding="{Binding Status}" Header="Status" />

                <DataGridTemplateColumn Width="Auto" Header="Actions">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <!--  Delete Order  -->
                                <Button
                                    Command="{Binding $parent[UserControl].((vm:DashboardViewModel)DataContext).DeleteOrderCommand}"
                                    CommandParameter="{Binding}"
                                    ToolTip.Tip="Delete Order">
                                    <Image
                                        Width="16"
                                        Height="16"
                                        Source="{SvgImage avares://Client/Assets/trash.svg}" />
                                </Button>
                                <!--  Open Order Folder  -->
                                <Button
                                    Command="{Binding $parent[UserControl].((vm:DashboardViewModel)DataContext).OpenOrderFolderCommand}"
                                    CommandParameter="{Binding Scanner.WatchedDir}"
                                    ToolTip.Tip="Open Order Folder">
                                    <Image
                                        Width="16"
                                        Height="16"
                                        Source="{SvgImage avares://Client/Assets/folder-open.svg}" />
                                </Button>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>

            <DataGrid.RowDetailsTemplate>
                <DataTemplate x:DataType="libs-models:Order">
                    <Border
                        Margin="5"
                        Padding="5"
                        BorderBrush="Gray"
                        BorderThickness="1">
                        <StackPanel>
                            <DataGrid
                                AutoGenerateColumns="False"
                                CanUserResizeColumns="True"
                                ItemsSource="{Binding Rolls}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn
                                        Binding="{Binding RollNumber}"
                                        Header="Roll #"
                                        IsReadOnly="True" />
                                    <DataGridTemplateColumn Header="Created" SortMemberPath="DateCreated">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock VerticalAlignment="Center">
                                                    <TextBlock.Text>
                                                        <Binding Converter="{StaticResource NullableDateTimeConverter}" Path="DateCreated" />
                                                    </TextBlock.Text>
                                                </TextBlock>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="Updated" SortMemberPath="DateUpdated">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock VerticalAlignment="Center">
                                                    <TextBlock.Text>
                                                        <Binding Converter="{StaticResource NullableDateTimeConverter}" Path="DateUpdated" />
                                                    </TextBlock.Text>
                                                </TextBlock>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn
                                        Binding="{Binding Status, Converter={StaticResource EnumDescriptionConverter}}"
                                        Header="Status"
                                        IsReadOnly="True" />

                                    <!--  Button Group Column  -->
                                    <DataGridTemplateColumn Width="Auto" Header="Actions">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Spacing="5">
                                                    <!--  Start/Resume Scanning (hidden for SP500Auto)  -->
                                                    <Button
                                                        Command="{Binding $parent[UserControl].((vm:DashboardViewModel)DataContext).StartResumeScanningRollCommand}"
                                                        CommandParameter="{Binding}"
                                                        ToolTip.Tip="Start/Resume Scanning">
                                                        <Button.IsVisible>
                                                            <MultiBinding Converter="{StaticResource RollActionVis}">
                                                                <Binding Path="Status" />
                                                                <Binding Source="start" />
                                                                <Binding Path="$parent[DataGrid].DataContext.Scanner.Profile.StrategyClassName" />
                                                            </MultiBinding>
                                                        </Button.IsVisible>
                                                        <Image
                                                            Width="16"
                                                            Height="16"
                                                            Source="{SvgImage avares://Client/Assets/play.svg}" />
                                                    </Button>

                                                    <!--  Pause Scanning (hidden for SP500Auto)  -->
                                                    <Button
                                                        Command="{Binding $parent[UserControl].((vm:DashboardViewModel)DataContext).PauseScanningRollCommand}"
                                                        CommandParameter="{Binding}"
                                                        ToolTip.Tip="Pause Scanning">
                                                        <Button.IsVisible>
                                                            <MultiBinding Converter="{StaticResource RollActionVis}">
                                                                <Binding Path="Status" />
                                                                <Binding Source="pause" />
                                                                <Binding Path="$parent[DataGrid].DataContext.Scanner.Profile.StrategyClassName" />
                                                            </MultiBinding>
                                                        </Button.IsVisible>
                                                        <Image
                                                            Width="16"
                                                            Height="16"
                                                            Source="{SvgImage avares://Client/Assets/pause-outline.svg}" />
                                                    </Button>

                                                    <!--  Complete Roll (hidden for SP500Auto)  -->
                                                    <Button
                                                        Command="{Binding $parent[UserControl].((vm:DashboardViewModel)DataContext).CompleteRollCommand}"
                                                        CommandParameter="{Binding}"
                                                        ToolTip.Tip="Complete Roll">
                                                        <Button.IsVisible>
                                                            <MultiBinding Converter="{StaticResource RollActionVis}">
                                                                <Binding Path="Status" />
                                                                <Binding Source="complete" />
                                                                <Binding Path="$parent[DataGrid].DataContext.Scanner.Profile.StrategyClassName" />
                                                            </MultiBinding>
                                                        </Button.IsVisible>
                                                        <Image
                                                            Width="16"
                                                            Height="16"
                                                            Source="{SvgImage avares://Client/Assets/progress-complete.svg}" />
                                                    </Button>

                                                    <!--  Start Auto-Export (SP500Auto only)  -->
                                                    <Button
                                                        Command="{Binding $parent[UserControl].((vm:DashboardViewModel)DataContext).StartExportCommand}"
                                                        CommandParameter="{Binding}"
                                                        ToolTip.Tip="Start Auto-Export">
                                                        <Button.IsVisible>
                                                            <MultiBinding Converter="{StaticResource RollActionVis}">
                                                                <Binding Path="Status" />
                                                                <Binding Source="startexport" />
                                                                <Binding Path="$parent[DataGrid].DataContext.Scanner.Profile.StrategyClassName" />
                                                            </MultiBinding>
                                                        </Button.IsVisible>
                                                        <Image
                                                            Width="16"
                                                            Height="16"
                                                            Source="{SvgImage avares://Client/Assets/play.svg}" />
                                                    </Button>

                                                    <!--  Stop Auto-Export (SP500Auto only)  -->
                                                    <Button
                                                        Command="{Binding $parent[UserControl].((vm:DashboardViewModel)DataContext).StopExportCommand}"
                                                        CommandParameter="{Binding}"
                                                        ToolTip.Tip="Stop Auto-Export">
                                                        <Button.IsVisible>
                                                            <MultiBinding Converter="{StaticResource RollActionVis}">
                                                                <Binding Path="Status" />
                                                                <Binding Source="stopexport" />
                                                                <Binding Path="$parent[DataGrid].DataContext.Scanner.Profile.StrategyClassName" />
                                                            </MultiBinding>
                                                        </Button.IsVisible>
                                                        <Image
                                                            Width="16"
                                                            Height="16"
                                                            Source="{SvgImage avares://Client/Assets/pause-outline.svg}" />
                                                    </Button>

                                                    <!--  Reset Roll  -->
                                                    <Button
                                                        Command="{Binding $parent[UserControl].((vm:DashboardViewModel)DataContext).ResetRollCommand}"
                                                        CommandParameter="{Binding}"
                                                        ToolTip.Tip="Reset Roll Progress">
                                                        <Button.IsVisible>
                                                            <MultiBinding Converter="{StaticResource RollActionVis}">
                                                                <Binding Path="Status" />
                                                                <Binding Source="reset" />
                                                            </MultiBinding>
                                                        </Button.IsVisible>
                                                        <Image
                                                            Width="16"
                                                            Height="16"
                                                            Source="{SvgImage avares://Client/Assets/reset.svg}" />
                                                    </Button>

                                                    <!--  Delete Roll  -->
                                                    <Button
                                                        Command="{Binding $parent[UserControl].((vm:DashboardViewModel)DataContext).DeleteRollCommand}"
                                                        CommandParameter="{Binding}"
                                                        ToolTip.Tip="Delete Roll">
                                                        <Button.IsVisible>
                                                            <MultiBinding Converter="{StaticResource RollActionVis}">
                                                                <Binding Path="Status" />
                                                                <Binding Source="delete" />
                                                            </MultiBinding>
                                                        </Button.IsVisible>
                                                        <Image
                                                            Width="16"
                                                            Height="16"
                                                            Source="{SvgImage avares://Client/Assets/trash.svg}" />
                                                    </Button>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>

                            <!--  "+" Button at bottom  -->
                            <Button
                                Grid.Row="1"
                                Margin="0,10,0,0"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                Command="{Binding $parent[UserControl].((vm:DashboardViewModel)DataContext).ShowAddRollModalCommand}"
                                CommandParameter="{Binding OrderId}"
                                Content="+ Add Roll"
                                FontSize="18" />
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </DataGrid.RowDetailsTemplate>
        </DataGrid>

        <!--  Loading Layer  -->
        <Border
            Grid.Row="3"
            Background="White"
            IsVisible="{Binding IsLoading}"
            Opacity="0.8">
            <Grid>
                <ProgressBar
                    Width="150"
                    Height="10"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    IsIndeterminate="True" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
