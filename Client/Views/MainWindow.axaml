<Window
    x:Class="Client.Views.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:Client.ViewModels"
    Title="ScanLab"
    Width="900"
    Height="600"
    MinWidth="900"
    MinHeight="600"
    x:DataType="vm:MainWindowViewModel"
    Icon="/Assets/avalonia-logo.ico"
    mc:Ignorable="d">

    <Design.DataContext>
        <!--
            This only sets the DataContext for the previewer in an IDE,
            to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs)
        -->
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <DockPanel>
        <!-- <DockPanel
            Width="43"
            Background="LightGray"
            DockPanel.Dock="Left">-->

        <Grid Background="LightGray">
            <!--  Define the grid structure  -->
            <Grid.RowDefinitions>
                <!--  Top buttons take equal space, but settings button is floated at bottom  -->
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <!--  Spacer to push settings button to bottom  -->
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Button Grid.Row="0" HorizontalAlignment="Stretch" VerticalAlignment="Bottom" Width="50" Height="50"
                Command="{Binding NavigateCommand}"
                CommandParameter="Dashboard"
                DockPanel.Dock="Top"
                ToolTip.Tip="Orders">
                <Image
                    Width="25"
                    Height="25"
                    Source="{SvgImage avares://Client/Assets/to-do.svg}" />
            </Button>
            <Button Grid.Row="1" HorizontalAlignment="Stretch" VerticalAlignment="Bottom" Width="50" Height="50"
                Command="{Binding NavigateCommand}"
                CommandParameter="OrderForm"
                DockPanel.Dock="Top"
                ToolTip.Tip="Order Form">
                <Image
                    Width="25"
                    Height="25"
                    Source="{SvgImage avares://Client/Assets/form.svg}" />
            </Button>
            <!--  Spacer (push the settings button to the bottom)  -->
            <GridSplitter
                Grid.Row="2"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Background="LightGray"/>
            <Button Grid.Row="3" HorizontalAlignment="Stretch" VerticalAlignment="Bottom" Width="50" Height="50"
                Command="{Binding NavigateCommand}"
                CommandParameter="Settings"
                Content="Settings"
                DockPanel.Dock="Bottom"
                ToolTip.Tip="Settings">
                <Image
                    Width="25"
                    Height="25"
                    Source="{SvgImage avares://Client/Assets/settings.svg}" />
            </Button>
        </Grid>
        <!-- </DockPanel> -->

        <!--  Content Area  -->
        <ContentControl Content="{Binding CurrentView}" />
    </DockPanel>
</Window>
