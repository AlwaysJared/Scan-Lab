<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="Client.Pages.DashboardPage"
             Title="Dashboard">

    <ScrollView>
        <StackLayout Padding="20"
                     Spacing="10">

            <SearchBar x:Name="OrderSearchBar"
                       Placeholder="Search Orders"
                       TextChanged="OnSearchTextChanged"
                       HorizontalOptions="FillAndExpand"/>

            <CollectionView x:Name="OrdersCollectionView"
                            ItemsSource="{Binding Orders}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <toolkit:Expander>
                            <toolkit:Expander.Header>
                                <Grid Padding="10"
                                      BackgroundColor="LightGray">
                                    <Label Text="{Binding OrderId}"
                                           FontSize="18"
                                           VerticalOptions="Center"/>
                                    <Label Text="{Binding Status}"
                                           FontSize="14"
                                           VerticalOptions="Center"
                                           HorizontalOptions="EndAndExpand"/>
                                </Grid>
                            </toolkit:Expander.Header>

                            <toolkit:Expander.Content>
                                <CollectionView ItemsSource="{Binding Rolls}">
                                    <CollectionView.ItemTemplate>
                                        <DataTemplate>
                                            <!-- Row Grid -->
                                            <Grid Padding="10"
                                                    ColumnDefinitions="Auto, *"
                                                    ColumnSpacing="10">

                                                <!-- Roll Number Label -->
                                                <Label Text="{Binding RollNumber, StringFormat='Roll # {0}'}"
                                                       FontSize="16"
                                                       VerticalOptions="Center"
                                                       Grid.Column="0"/>

                                                <!-- Button Group -->
                                                <Grid Grid.Column="1"
                                                        HorizontalOptions="End">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <!-- Start/Resume Scanning Button -->
                                                    <ImageButton Source="start_icon.png"
                                                                 Command="{Binding Source={x:Reference DashboardPage}, Path=StartResumeScanningCommand}"
                                                                 CommandParameter="{Binding .}"
                                                                 HeightRequest="30"
                                                                 WidthRequest="30"
                                                                 Grid.Column="0"
                                                                 ToolTipProperties.Text="Start/Resume Scanning"/>

                                                    <!-- Pause Scanning Button -->
                                                    <ImageButton Source="pause_icon.png"
                                                                 Command="{Binding Source={x:Reference DashboardPage}, Path=PauseScanningCommand}"
                                                                 CommandParameter="{Binding .}"
                                                                 HeightRequest="30"
                                                                 WidthRequest="30"
                                                                 Grid.Column="1"
                                                                 ToolTipProperties.Text="Pause Scanning"/>

                                                    <!-- Delete Roll Button -->
                                                    <ImageButton Source="delete_icon.png"
                                                                 Command="{Binding Source={x:Reference DashboardPage}, Path=DeleteRollCommand}"
                                                                 CommandParameter="{Binding .}"
                                                                 HeightRequest="30"
                                                                 WidthRequest="30"
                                                                 Grid.Column="2"
                                                                 ToolTipProperties.Text="Delete Roll"/>
                                                </Grid>

                                            </Grid>
                                        </DataTemplate>
                                    </CollectionView.ItemTemplate>
                                </CollectionView>
                            </toolkit:Expander.Content>
                        </toolkit:Expander>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </StackLayout>
    </ScrollView>
</ContentPage>

