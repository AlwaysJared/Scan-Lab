<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="Client.Pages.DashboardPage"
             x:Name="DashboardPageRef"
             Title="Dashboard">
    <Grid Padding="10"
          RowDefinitions="Auto, *">
        <Grid Grid.Row="0"
              Padding="10"
              ColumnDefinitions="*, Auto"
              ColumnSpacing="10">
            <SearchBar Grid.Column="0"
                       Placeholder="Search by Order ID..."
                       Text="{Binding SearchQuery, Mode=TwoWay}"
                       HeightRequest="40"/>

            <!-- Order Status Dropdown -->
            <Picker Grid.Column="1"
                    ItemsSource="{Binding OrderStatusOptions}"
                    SelectedItem="{Binding SelectedOrderStatus, Mode=TwoWay, Path=Value}"
                    ItemDisplayBinding="{Binding Key}"/>
        </Grid>
        <ScrollView Grid.Row="1">
            <CollectionView x:Name="OrdersCollectionView"
                            ItemsSource="{Binding Orders}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <toolkit:Expander>
                            <toolkit:Expander.Header>
                                <Grid Padding="10"
                                      BackgroundColor="LightGray">

                                    <Grid.Triggers>
                                        <!-- Highlight orders with "Processing" or "Scanning In Progress" status -->
                                        <DataTrigger TargetType="Grid"
                                                     Binding="{Binding Status}"
                                                     Value="Processing">
                                            <Setter Property="BackgroundColor"
                                                    Value="#FF5148D4"/>
                                        </DataTrigger>
                                    </Grid.Triggers>

                                    <Label Text="{Binding OrderId}"
                                           FontSize="18"
                                           VerticalOptions="Center"/>
                                    <Label Text="{Binding Status}"
                                           FontSize="14"
                                           VerticalOptions="Center"
                                           HorizontalOptions="EndAndExpand"/>
                                </Grid>
                            </toolkit:Expander.Header>

                            <toolkit:Expander.Content>
                                <CollectionView ItemsSource="{Binding Rolls}">
                                    <CollectionView.ItemTemplate>
                                        <DataTemplate>
                                            <!-- Row Grid -->
                                            <Grid Padding="10"
                                                  ColumnDefinitions="Auto, *"
                                                  ColumnSpacing="10">

                                                <Grid.Triggers>
                                                    <!-- Highlight rolls with "Processing" or "Scanning In Progress" status -->
                                                    <DataTrigger TargetType="Grid"
                                                                 Binding="{Binding Status}"
                                                                 Value="Processing">
                                                        <Setter Property="BackgroundColor"
                                                                Value="#FF0059FF"/>
                                                    </DataTrigger>
                                                    <DataTrigger TargetType="Grid"
                                                                 Binding="{Binding Status}"
                                                                 Value="ScanningInProgress">
                                                        <Setter Property="BackgroundColor"
                                                                Value="LightGreen"/>
                                                    </DataTrigger>
                                                </Grid.Triggers>

                                                <!-- Roll Number Label -->
                                                <Label Text="{Binding RollNumber, StringFormat='Roll # {0}'}"
                                                       FontSize="16"
                                                       VerticalOptions="Center"
                                                       Grid.Column="0"/>

                                                <!-- Button Group -->
                                                <Grid Grid.Column="1"
                                                      HorizontalOptions="End">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <!-- Start/Resume Scanning Button -->
                                                    <ImageButton Source="start_icon.png"
                                                                 Command="{Binding Source={x:Reference DashboardPageRef}, Path=StartResumeScanningCommand}"
                                                                 CommandParameter="{Binding .}"
                                                                 HeightRequest="30"
                                                                 WidthRequest="30"
                                                                 Grid.Column="0"
                                                                 ToolTipProperties.Text="Start/Resume Scanning">

                                                        <ImageButton.Triggers>
                                                            <DataTrigger TargetType="ImageButton"
                                                                         Binding="{Binding Status}"
                                                                         Value="Created">
                                                                <Setter Property="IsVisible"
                                                                        Value="True"/>
                                                            </DataTrigger>
                                                            <DataTrigger TargetType="ImageButton"
                                                                         Binding="{Binding Status}"
                                                                         Value="ScanningPaused">
                                                                <Setter Property="IsVisible"
                                                                        Value="True"/>
                                                            </DataTrigger>
                                                            <DataTrigger TargetType="ImageButton"
                                                                         Binding="{Binding Status}"
                                                                         Value="ScanningInProgress">
                                                                <Setter Property="IsVisible"
                                                                        Value="False"/>
                                                            </DataTrigger>
                                                            <DataTrigger TargetType="ImageButton"
                                                                         Binding="{Binding Status}"
                                                                         Value="Processing">
                                                                <Setter Property="IsVisible"
                                                                        Value="False"/>
                                                            </DataTrigger>
                                                            <DataTrigger TargetType="ImageButton"
                                                                         Binding="{Binding Status}"
                                                                         Value="Processed">
                                                                <Setter Property="IsVisible"
                                                                        Value="False"/>
                                                            </DataTrigger>
                                                        </ImageButton.Triggers>

                                                    </ImageButton>

                                                    <!-- Pause Scanning Button -->
                                                    <ImageButton Source="pause_icon.png"
                                                                 Command="{Binding Source={x:Reference DashboardPageRef}, Path=PauseScanningCommand}"
                                                                 CommandParameter="{Binding .}"
                                                                 HeightRequest="30"
                                                                 WidthRequest="30"
                                                                 Grid.Column="1"
                                                                 ToolTipProperties.Text="Pause Scanning"
                                                                 IsVisible="False">

                                                        <ImageButton.Triggers>
                                                            <DataTrigger TargetType="ImageButton"
                                                                         Binding="{Binding Status}"
                                                                         Value="ScanningInProgress">
                                                                <Setter Property="IsVisible"
                                                                        Value="True"/>
                                                            </DataTrigger>
                                                        </ImageButton.Triggers>
                                                    </ImageButton>

                                                    <ImageButton Source="complete_icon.png"
                                                                 Command="{Binding Source={x:Reference DashboardPageRef}, Path=CompleteScanningCommand}"
                                                                 CommandParameter="{Binding .}"
                                                                 HeightRequest="30"
                                                                 WidthRequest="30"
                                                                 Grid.Column="2"
                                                                 ToolTipProperties.Text="Complete Scanning"
                                                                 IsVisible="False">
                                                        <ImageButton.Triggers>
                                                            <DataTrigger TargetType="ImageButton"
                                                                         Binding="{Binding Status}"
                                                                         Value="ScanningInProgress">
                                                                <Setter Property="IsVisible"
                                                                        Value="True"/>
                                                            </DataTrigger>
                                                        </ImageButton.Triggers>
                                                    </ImageButton>

                                                    <!-- Delete Roll Button -->
                                                    <ImageButton Source="delete_icon.png"
                                                                 Command="{Binding Source={x:Reference DashboardPageRef}, Path=DeleteRollCommand}"
                                                                 CommandParameter="{Binding .}"
                                                                 HeightRequest="30"
                                                                 WidthRequest="30"
                                                                 Grid.Column="3"
                                                                 ToolTipProperties.Text="Delete Roll">
                                                        <ImageButton.Triggers>
                                                            <DataTrigger TargetType="ImageButton"
                                                                         Binding="{Binding Status}"
                                                                         Value="Processed">
                                                                <Setter Property="IsVisible"
                                                                        Value="False"/>
                                                            </DataTrigger>
                                                        </ImageButton.Triggers>
                                                    </ImageButton>
                                                </Grid>
                                            </Grid>
                                        </DataTemplate>
                                    </CollectionView.ItemTemplate>
                                </CollectionView>
                            </toolkit:Expander.Content>
                        </toolkit:Expander>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </ScrollView>
    </Grid>
</ContentPage>