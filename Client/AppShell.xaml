<?xml version="1.0" encoding="utf-8" ?>
<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
       xmlns:pages="clr-namespace:Client.Pages"
       x:Class="Client.AppShell">

    <!-- Dashboard Navigation -->
    <FlyoutItem Title="Dashboard" Icon="icon_dashboard.png">
        <ShellContent ContentTemplate="{DataTemplate pages:DashboardPage}" />
    </FlyoutItem>

    <!-- Order Form Navigation -->
    <FlyoutItem Title="Order Form" Icon="icon_order_form.png">
        <ShellContent ContentTemplate="{DataTemplate pages:OrderFormPage}" />
    </FlyoutItem>

    <!-- Settings Navigation -->
    <FlyoutItem Title="Settings" Icon="icon_settings.png">
        <ShellContent ContentTemplate="{DataTemplate pages:SettingsPage}" />
    </FlyoutItem>

</Shell>
